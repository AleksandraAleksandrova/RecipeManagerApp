<Window x:Class="RecipeManager.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RecipeManager.WPF"
        xmlns:controls="clr-namespace:RecipeManager.WPF.Controls"
        xmlns:models="clr-namespace:RecipeManager.Core.Models;assembly=RecipeManager.Core"
        xmlns:vm="clr-namespace:RecipeManager.Core.ViewModels;assembly=RecipeManager.Core"
        mc:Ignorable="d"
        Title="Recipe Manager" Height="600" Width="900"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Background="#F5F7FA">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="5*" />
        </Grid.ColumnDefinitions>

        <!-- HEADER BAR -->
        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="&#x21bb; Refresh List" Command="{Binding LoadRecipesCommand}" Width="150" Height="40" FontWeight="Bold" Background="White" Foreground="#333" BorderBrush="#DDD" BorderThickness="1" Cursor="Hand"/>
            <Button Grid.Column="2" Content="+ Create New Recipe" Command="{Binding BeginCreateRecipeCommand}" Width="160" Height="40" FontWeight="Bold" Background="#2E7D32" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </Grid>

        <!-- ALERTS -->
        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,15">
            <Border Background="#FFEBEE" BorderBrush="#D32F2F" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,5">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#D32F2F" FontWeight="Bold" />
            </Border>

            <Border Background="#E8F5E9" BorderBrush="#388E3C" BorderThickness="1" CornerRadius="4" Padding="10">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SuccessMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SuccessMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding SuccessMessage}" Foreground="#388E3C" FontWeight="Bold"/>
            </Border>
        </StackPanel>

        <!-- LEFT: MASTER RECIPE LIST -->
        <Border Grid.Row="2" Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White">
            <TabControl BorderThickness="0" Background="Transparent">
                <TabItem Header="Recipes">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="10">
                            <TextBlock Text="Search" FontWeight="Bold" Foreground="#2C3E50" FontSize="16" Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Title:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#34495E" Width="70" Margin="0,0,10,0"/>
                                <TextBox Text="{Binding SearchRecipeTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="200" Height="35" Padding="5"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Category:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#34495E" Width="70" Margin="0,0,10,0"/>
                                <ComboBox ItemsSource="{Binding Categories}" DisplayMemberPath="Name" SelectedValuePath="Id" 
                                          SelectedValue="{Binding SelectedFilterCategoryId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                          Width="200" Height="35" Padding="5"/>
                                <Button Content="Clear filter" Width="80" Height="35" Margin="10,0,0,0" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"
                                        Command="{Binding ClearRecipeFilterCommand}" />
                            </StackPanel>
                        </StackPanel>
                        <controls:GenericListControl Grid.Row="1"
                            ItemsSource="{Binding Recipes}" 
                            SelectedItem="{Binding SelectedRecipe, Mode=TwoWay}"
                            ColumnNames="{Binding RecipeListColumns}" />
                    </Grid>
                </TabItem>
                <TabItem Header="Categories">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
                            <TextBlock Text="Search Category:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#34495E" Margin="0,0,10,0"/>
                            <TextBox Text="{Binding SearchCategoryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150" Height="35" Padding="5" Margin="0,0,20,0"/>
                            <Button Content="Clear" Width="80" Height="35" Margin="10,0,0,0" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"
                                    Command="{Binding ClearCategoryFilterCommand}" />
                        </StackPanel>
                        <controls:GenericListControl Grid.Row="1"
                            ItemsSource="{Binding Categories}" 
                            ColumnNames="{Binding CategoryListColumns}" />
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>

        <!-- SPLITTER -->
        <GridSplitter Grid.Row="2" Grid.Column="1" Width="5" HorizontalAlignment="Center" Background="Transparent"/>

        <!-- RIGHT: CONTEXT AREA (Placeholder, Create, Edit) -->
        <Border Grid.Row="2" Grid.Column="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White">
            <Grid Margin="20">
                <!-- 1. EMPTY PLACEHOLDER -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsCreatingMode}" Value="False" />
                                        <Condition Binding="{Binding SelectedRecipe}" Value="{x:Null}" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="No recipe selected" FontSize="20" FontWeight="Bold" Foreground="#BDC3C7" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Select a recipe from the list on the left to view details&#x0a;or click '+ Create New Recipe' to add one." Foreground="#95A5A6" TextAlignment="Center" LineHeight="20"/>
                </StackPanel>

                <!-- 2. CREATE MODE VIEW -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding IsCreatingMode, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Create New Recipe" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>
                        
                        <TextBlock Text="Recipe Name *" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NewRecipeName, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,15" Background="#F9FBFD" BorderBrush="#D6DBDF"/>

                        <TextBlock Text="Brief Description" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NewRecipeDescription, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" Height="60" Padding="8" Margin="0,0,0,15" Background="#F9FBFD" BorderBrush="#D6DBDF"/>

                        <TextBlock Text="Ingredients" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NewRecipeIngredients, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" Height="100" Padding="8" Margin="0,0,0,15" Background="#F9FBFD" BorderBrush="#D6DBDF"/>

                        <TextBlock Text="Instructions" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NewRecipeInstructions, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" Height="150" Padding="8" Margin="0,0,0,20" Background="#F9FBFD" BorderBrush="#D6DBDF"/>

                        <TextBlock Text="Category" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding Categories}" DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding NewRecipeCategoryId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel" Command="{Binding CancelCreateCommand}" Width="100" Height="40" Background="Transparent" Foreground="#666" BorderThickness="0" Margin="0,0,10,0" FontWeight="Bold" Cursor="Hand"/>
                            <Button Content="Save Recipe" Command="{Binding CreateRecipeCommand}" Width="150" Height="40" Background="#2980B9" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- 3. EDIT / DETAILS VIEW -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsCreatingMode}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                                <DataTrigger Binding="{Binding SelectedRecipe}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel Margin="0,0,10,0">
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Recipe Details" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                            <Button Content="Delete" Command="{Binding DeleteRecipeCommand}" Width="80" Height="30" HorizontalAlignment="Right" Background="#E74C3C" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
                        </Grid>

                        <TextBlock Text="Title" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SelectedRecipe.Title, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,15" Background="#F9FBFD" BorderBrush="#D6DBDF"/>

                        <TextBlock Text="Description" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SelectedRecipe.Description, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" Height="60" Padding="8" Margin="0,0,0,15" Background="#F9FBFD" BorderBrush="#D6DBDF"/>

                        <TextBlock Text="Ingredients" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SelectedRecipe.Ingredients, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" Height="100" Padding="8" Margin="0,0,0,15" Background="#F9FBFD" BorderBrush="#D6DBDF"/>

                        <TextBlock Text="Instructions" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SelectedRecipe.Instructions, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" Height="150" Padding="8" Margin="0,0,0,20" Background="#F9FBFD" BorderBrush="#D6DBDF"/>

                        <TextBlock Text="Category" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding Categories}" DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding SelectedRecipe.CategoryId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" />

                        <Button Content="Save Changes" Command="{Binding UpdateRecipeCommand}" Width="150" Height="40" HorizontalAlignment="Left" Background="#27AE60" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Margin="0,0,0,30"/>

                        <!-- Activity Log -->
                        <Border BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Revisions" FontSize="18" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,15"/>
                                <ItemsControl ItemsSource="{Binding SelectedRecipe.Revisions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F4F6F6" CornerRadius="6" Padding="15" Margin="0,0,0,10" BorderBrush="#E0E0E0" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Icon -->
                                                    <TextBlock Grid.Column="0" Text="&#x1F4DD;" FontSize="24" Foreground="#3498DB" Margin="0,0,15,0" VerticalAlignment="Center"/>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding ModifiedBy}" FontWeight="SemiBold" FontSize="14" Foreground="#2C3E50" Margin="0,0,10,0" VerticalAlignment="Bottom"/>
                                                            <TextBlock Text="{Binding ModifiedAt, StringFormat='MMM dd, yyyy HH:mm'}" FontSize="12" Foreground="#95A5A6" VerticalAlignment="Bottom"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <Button Grid.Column="2" Content="View Diff" Command="{Binding DataContext.ViewRevisionCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Padding="15,6" Background="White" BorderBrush="#D6DBDF" BorderThickness="1" Cursor="Hand" Foreground="#2C3E50" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
