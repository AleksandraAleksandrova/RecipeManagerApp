@page "/categories"
@rendermode InteractiveServer
@using RecipeManager.Core.Models
@using RecipeManager.Core.Services
@using RecipeManager.Core.ViewModels
@inject MainViewModel ViewModel
@implements IDisposable

<PageTitle>Categories</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <MudText Typo="Typo.h3">Categories</MudText>
    </div>

    <MudPaper Class="pa-4 mb-4" Elevation="3">
        <div class="mb-3 d-flex align-center">
            <MudText Typo="Typo.subtitle1" Class="mr-4">Select filters:</MudText>
            <MudCheckBox T="bool" Label="Name" Value="ViewModel.IncludeCategoryNameFilter" ValueChanged="OnIncludeNameChanged" Color="Color.Primary" />
            <MudCheckBox T="bool" Label="Description" Value="ViewModel.IncludeCategoryDescriptionFilter" ValueChanged="OnIncludeDescChanged" Color="Color.Primary" />
            <MudCheckBox T="bool" Label="Common Ingredients" Value="ViewModel.IncludeCategoryIngredientsFilter" ValueChanged="OnIncludeIngredientsChanged" Color="Color.Primary" />
        </div>
        <MudGrid>
            @if (ViewModel.IncludeCategoryNameFilter)
            {
                <MudItem xs="12" md="3">
                    <MudTextField T="string" Value="@ViewModel.SearchCategoryName" Label="Search Name" Placeholder="e.g. Dinner" 
                                  Immediate="true" ValueChanged="OnNameChangedStr" />
                </MudItem>
            }

            @if (ViewModel.IncludeCategoryDescriptionFilter)
            {
                <MudItem xs="12" md="3">
                    <MudTextField T="string" Value="@ViewModel.SearchCategoryDescription" Label="Search Description" Placeholder="e.g. Evening meal" 
                                  Immediate="true" ValueChanged="OnDescChangedStr" />
                </MudItem>
            }

            @if (ViewModel.IncludeCategoryIngredientsFilter)
            {
                <MudItem xs="12" md="3">
                    <MudTextField T="string" Value="@ViewModel.SearchCategoryIngredients" Label="Search Common Ingredients" Placeholder="e.g. Pork" 
                                  Immediate="true" ValueChanged="OnIngredientsChangedStr" />
                </MudItem>
            }

            <MudItem xs="12" md="3" Class="d-flex align-end">
                <MudButton Variant="Variant.Outlined" Color="Color.Error" FullWidth="true" OnClick="ClearFilterAsync">Clear</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (!string.IsNullOrEmpty(ViewModel.ErrorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">
            @ViewModel.ErrorMessage
        </MudAlert>
    }

    @if (ViewModel.Categories == null)
    {
        <div class="d-flex justify-content-center p-5">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else if (!ViewModel.Categories.Any())
    {
        <MudAlert Severity="Severity.Info" Class="mb-4">
            No categories found.
        </MudAlert>
    }
    else
    {
        <MudPaper Elevation="3">
            <GenericTable 
                TItem="Category" 
                Items="ViewModel.Categories" 
                Columns="new List<string> { nameof(Category.Name), nameof(Category.Description), nameof(Category.CommonIngredients) }" />
        </MudPaper>
    }
</MudContainer>

@code {
    protected override async Task OnInitializedAsync()
    {
        ViewModel.PropertyChanged += OnViewModelPropertyChanged;
        if (ViewModel.Categories != null)
        {
            ViewModel.Categories.CollectionChanged += OnViewModelCategoriesChanged;
        }
        await ViewModel.LoadCategoriesAsync();
    }

    private void OnViewModelPropertyChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
    {
        if (e.PropertyName == nameof(ViewModel.Categories) && ViewModel.Categories != null)
        {
            ViewModel.Categories.CollectionChanged -= OnViewModelCategoriesChanged;
            ViewModel.Categories.CollectionChanged += OnViewModelCategoriesChanged;
        }
        InvokeAsync(StateHasChanged);
    }

    private void OnViewModelCategoriesChanged(object? sender, System.Collections.Specialized.NotifyCollectionChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task OnNameChangedStr(string value)
    {
        ViewModel.SearchCategoryName = value;
        await ViewModel.ApplyCategoryFiltersAsync();
    }

    private async Task OnDescChangedStr(string value)
    {
        ViewModel.SearchCategoryDescription = value;
        await ViewModel.ApplyCategoryFiltersAsync();
    }

    private async Task OnIngredientsChangedStr(string value)
    {
        ViewModel.SearchCategoryIngredients = value;
        await ViewModel.ApplyCategoryFiltersAsync();
    }

    private async Task OnIncludeNameChanged(bool value)
    {
        ViewModel.IncludeCategoryNameFilter = value;
        ViewModel.UpdateCategoryFilterColumns();
        if (!value) ViewModel.SearchCategoryName = string.Empty;
        await ViewModel.ApplyCategoryFiltersAsync();
    }

    private async Task OnIncludeDescChanged(bool value)
    {
        ViewModel.IncludeCategoryDescriptionFilter = value;
        ViewModel.UpdateCategoryFilterColumns();
        if (!value) ViewModel.SearchCategoryDescription = string.Empty;
        await ViewModel.ApplyCategoryFiltersAsync();
    }

    private async Task OnIncludeIngredientsChanged(bool value)
    {
        ViewModel.IncludeCategoryIngredientsFilter = value;
        ViewModel.UpdateCategoryFilterColumns();
        if (!value) ViewModel.SearchCategoryIngredients = string.Empty;
        await ViewModel.ApplyCategoryFiltersAsync();
    }

    private async Task ClearFilterAsync()
    {
        await ViewModel.ClearCategoryFilter();
    }

    public void Dispose()
    {
        ViewModel.PropertyChanged -= OnViewModelPropertyChanged;
        if (ViewModel.Categories != null)
        {
            ViewModel.Categories.CollectionChanged -= OnViewModelCategoriesChanged;
        }
    }
}
